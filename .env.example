# ───────────────────────────────────────────────────────────────────────────────
# Local development overrides — copy to .env (which is git-ignored).
#
# IMPORTANT: do NOT put a GitHub token here. The token belongs in the
# Cloudflare Worker as a secret, not in the browser bundle. Set it with:
#   npx wrangler secret put GITHUB_TOKEN
# ───────────────────────────────────────────────────────────────────────────────

# Where the browser should send GitHub API requests.
# Leave unset to use the production Worker URL hard-coded in src/api.ts.
# Set this when developing against a local Worker (`npm run worker:dev`).
VITE_PROXY_URL=http://localhost:8787
